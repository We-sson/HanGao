<Window
    x:Class="Robot_3D.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hx="http://helix-toolkit.org/wpf/SharpDX"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:Robot_3D"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="800"
    Height="450"
    DataContext="{Binding Source={StaticResource Locator}, Path=MainViewModel}"
    mc:Ignorable="d">
    <Grid>
        <hx:Viewport3DX
            BackgroundColor="Gray"
            Camera="{Binding Camera}"
            CoordinateSystemLabelForeground="White"
            EffectsManager="{Binding EffectsManager}"
            EnableD2DRendering="True"
            EnableDeferredRendering="True"
            EnableRenderFrustum="False"
            EnableSwapChainRendering="False"
            FixedRotationPoint="0,0,0"
            FixedRotationPointEnabled="False"
            IsViewCubeEdgeClicksEnabled="False"
            MSAA="Four"
            RotateAroundMouseDownPoint="True"
            ShowCameraInfo="True"
            ShowCameraTarget="True"
            ShowCoordinateSystem="True"
            ShowFrameDetails="True"
            ShowFrameRate="True"
            ShowTriangleCountInfo="True"
            ShowViewCube="True">
            <!--  模型阴影  -->
            <hx:ShadowMap3D
                AutoCoverCompleteScene="True"
                Intensity="0.8"
                OrthoWidth="1000" />
            <hx:AmbientLight3D Color="White" />


            <!--  地面网格  -->
            <!--
            <hx:AxisPlaneGridModel3D
                x:Name="plane"
                AutoSpacing="False"
                FadingFactor="0.03"
                GridColor="White"
                GridPattern="Tile"
                GridSpacing="1"
                PlaneColor="Gray"
                RenderShadowMap="True"
                UpAxis="Z"
                Offset="0" />-->





            <!--<hx:AmbientLight3D Color="Blue" />-->
            <hx:Element3DPresenter Content="{Binding GroupModel}" />
            <hx:DirectionalLight3D Direction="{Binding Camera.LookDirection}" Color="White" />


        </hx:Viewport3DX>

        <Button
            Width="100"
            Height=" 30"
            HorizontalAlignment="Left"
            VerticalAlignment="Top">

            <i:Interaction.Triggers>
                <i:EventTrigger EventName="Click">
                    <i:InvokeCommandAction
                        Command="{Binding Save_Date_File_Comm}"
                        CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}, Path=EventArgsConverter}"
                        PassEventArgsToCommand="True" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </Button>
    </Grid>
</Window>
